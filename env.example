# ──────────────────────────────────────────
# Banco de dados
# ──────────────────────────────────────────

# Formato longo (usado localmente com docker compose up db)
# PostgreSQL disponível em localhost:5435
ConnectionStrings__DefaultConnection=Host=localhost;Port=5435;Database=mechanics_software;Username=postgres;Password=postgres

# Formato alternativo (usado em produção / ambientes externos)
# DATABASE_URL=Host=<host>;Port=5432;Database=mechanics_software;Username=postgres;Password=postgres

# ──────────────────────────────────────────
# Autenticação JWT
# ──────────────────────────────────────────

# Obrigatório em produção — mínimo 32 caracteres
JWT_SECRET=dev-secret-change-in-production-min-32-chars!!

# Tempo de expiração do token em minutos (padrão: 60)
JWT_EXPIRATION_MINUTES=60

# ──────────────────────────────────────────
# Segurança
# ──────────────────────────────────────────

# Custo do BCrypt para hash de senhas (padrão: 12)
BCRYPT_SALT_ROUNDS=12

# ──────────────────────────────────────────
# Seed — usuário admin padrão
# ──────────────────────────────────────────

# E-mail do admin criado automaticamente na primeira execução
SEED_ADMIN_EMAIL=admin@mechanics.local

# Senha do admin criado automaticamente na primeira execução
SEED_ADMIN_PASSWORD=Admin@123

# ──────────────────────────────────────────
# Ambiente
# ──────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ──────────────────────────────────────────
# E-mail (SMTP)
# ──────────────────────────────────────────

# Servidor SMTP (ex.: smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# Porta SMTP — 587 para STARTTLS (recomendado), 465 para SSL
SMTP_PORT=587

# Usuário de autenticação (geralmente o próprio endereço de e-mail)
SMTP_USER=seu-email@gmail.com

# Senha ou App Password (Gmail com 2FA: myaccount.google.com/apppasswords)
SMTP_PASS=sua-senha-ou-app-password

# Endereço exibido como remetente no campo "De:"
SMTP_FROM=noreply@seudominio.com
